<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!--
		Export compliance. The app's only cryptography is standard,
		Apple-OS-provided: TLS via URLSession (Ktor Darwin) and SHA-256
		fingerprinting via CommonCrypto's CC_SHA256 for TOFU cert pinning.
		No SSH, VPN, bundled crypto libs, or proprietary algorithms. This
		qualifies for the Category 5 Part 2 exemption, so no export
		documentation upload is required at submission.
	-->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!--
		ATS configuration for Lunamux's self-signed TLS endpoints.

		NSAllowsLocalNetworking lets the app reach Bonjour/.local/IP-based
		hosts (the usual local-server scenario) without going through the
		standard ATS chain check.

		NSAllowsArbitraryLoads is required so that ATS does NOT reject the
		self-signed server cert before the URLSessionDelegate installed by
		:client's PinnedHttpClientFactory.ios gets a chance to inspect the
		server-trust challenge and either accept (capture/verify path) or
		cancel (pin mismatch). The delegate is the actual security check;
		ATS would otherwise pre-empt it with a generic chain failure.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>UIAppFonts</key>
	<array>
		<string>JetBrainsMono-Regular.ttf</string>
	</array>
</dict>
</plist>
